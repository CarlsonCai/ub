@using UmbracoSite.Services
@inject BankSiteRepository BankSiteRepo
@{
    var data = BankSiteRepo.Get();
    var settings = data.SiteSettings;
    var nav = settings.NavItems.Where(x => x.IsVisible).OrderBy(x => x.Sort).ToList();
    var footer = settings.FooterLinks.Where(x => x.IsVisible).OrderBy(x => x.Sort).ToList();
}
<!doctype html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="@(ViewData["Description"] ?? $"{settings.BrandName} 官方網站")" />
    <link rel="stylesheet" href="/bank-site.css" />
</head>
<body>
    <div class="topbar">
        <div class="container">
            <div>客服專線：@settings.ServicePhone（@settings.ServiceHours）</div>
            <div class="muted">
                <a href="/announcements">最新公告</a>
                <span style="margin: 0 10px; opacity: .35;">|</span>
                <a href="/articles">理財文章</a>
            </div>
        </div>
    </div>

    <header class="nav">
        <div class="container nav-wrap">
            <a href="/" class="brand">
                <span class="logo" aria-hidden="true"></span>
                <span>@settings.BrandName</span>
            </a>
            <nav class="menu">
                @foreach (var n in nav)
                {
                    <a href="@n.Href">@n.Label</a>
                }
            </nav>
            <a href="#" class="btn btn-outline">網銀登入</a>
        </div>
    </header>

    @RenderBody()

    <footer class="footer" style="margin-top: 30px;">
        <div class="container" style="display:flex; justify-content:space-between; gap:12px; flex-wrap: wrap;">
            <div class="muted">@settings.BrandName © @DateTime.Now.Year</div>
            <div class="muted" style="display:flex; gap: 12px; flex-wrap: wrap;">
                @foreach (var f in footer)
                {
                    <a href="@f.Href" style="color:inherit; text-decoration:none;">@f.Label</a>
                }
            </div>
        </div>
    </footer>
</body>
</html>

