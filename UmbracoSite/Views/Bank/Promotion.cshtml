@model UmbracoSite.Models.Promotion
@{
    Layout = "~/Views/Shared/_BankLayout.cshtml";
    ViewData["Title"] = Model.Title;
}

<main>
    <section class="section">
        <div class="container">
            <div class="card">
                <div class="badge @(Model.IsPinned ? "warn" : "ok")">@(Model.IsPinned ? "置頂" : "活動")</div>
                <h2 style="margin-top: 10px;">@Model.Title</h2>
                <p class="muted">@Model.Summary</p>
                <div style="margin-top: 14px;">
                    @Html.Raw(Model.BodyHtml ?? "")
                </div>
                <div style="margin-top: 18px;">
                    <a class="btn btn-outline" href="/promotions">回活動列表</a>
                </div>
            </div>
        </div>
    </section>
</main>

