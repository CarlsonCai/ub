@model List<UmbracoSite.Models.Promotion>
@{
    Layout = "~/Views/Shared/_BankLayout.cshtml";
    ViewData["Title"] = "活動";
}

<main>
    <section class="section section-alt">
        <div class="container">
            <div class="split">
                <h2>活動優惠</h2>
                <div class="muted">共 @Model.Count 項</div>
            </div>

            <div class="grid-3" style="margin-top: 12px;">
                @if (!Model.Any())
                {
                    <div class="card" style="grid-column: 1 / -1;">目前沒有已發布活動。</div>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        <article class="card">
                            <div class="badge @(p.IsPinned ? "warn" : "ok")">@(p.IsPinned ? "置頂" : "活動")</div>
                            <h3 style="margin-top: 8px;"><a href="/promotions/@p.Slug" style="color: inherit; text-decoration: none;">@p.Title</a></h3>
                            <p class="muted">@p.Summary</p>
                            <div style="margin-top: 10px;">
                                <a class="btn btn-outline" href="/promotions/@p.Slug">查看活動</a>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
    </section>
</main>

