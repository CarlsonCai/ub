@model UmbracoSite.Models.Product
@{
    Layout = "~/Views/Shared/_BankLayout.cshtml";
    ViewData["Title"] = Model.Title;
}

<main>
    <section class="section">
        <div class="container">
            <div class="card">
                <h2 style="margin-top: 0;">@Model.Title</h2>
                <p class="muted">@Model.Summary</p>
                <div style="margin-top: 14px;">
                    @Html.Raw(Model.BodyHtml ?? "")
                </div>
                <div style="margin-top: 18px;">
                    <a class="btn btn-outline" href="/products">回產品列表</a>
                </div>
            </div>
        </div>
    </section>
</main>

